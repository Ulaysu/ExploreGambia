{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "https://localhost:7297",
    "Audience": "https://localhost:7297"
  },
  "RateLimiting": {
    "Login": {
      "PermitLimit": 5,
      "WindowSeconds": 60
    },
    "Registration": {
      "PermitLimit": 3,
      "WindowSeconds": 600
    },
    "RefreshToken": {
      "PermitLimit": 10,
      "WindowSeconds": 60
    }
  },
  "ForwardedHeaders": {
    "KnownProxies": [],
    "KnownNetworks": []
  },
  "ModemPay": {
    "Currency": "GMD",
    "BaseUrl": "https://api.modempay.com",
    "TransactionPathTemplate": "/transactions/{transactionId}"
  }
}
